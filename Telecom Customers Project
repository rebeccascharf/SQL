--Write a query that selects the customer id of all the customers who are subscribed to Cell Phone service products.

SELECT customer_id
FROM customer_subscriptions
WHERE product_id IN (SELECT product_id
FROM products
WHERE product_type='Cell Phone Service');

--Write a query that will select the email address of all the customers with the "Internet" product type.

SELECT email
FROM customer_subscriptions
WHERE product_id
IN (SELECT product_id
FROM products
WHERE product_type='Internet');

--Write a query that will select the emails of all customers who are paying more than the average price for internet.

SELECT email
FROM customer_subscriptions
WHERE price > (SELECT AVG(monthly_price) FROM products WHERE product_type='Internet');

--Which customers are subscribed to Cell Phone Service products?

SELECT customer_id
FROM customer_subscriptions
WHERE product_id IN (
    SELECT product_id
    FROM products
    WHERE product_type = 'Cell Phone Service');

--Which customers are subscribed to Internet products?

SELECT email
FROM customer_subscriptions
WHERE product_id IN (
    SELECT product_id
    FROM products
    WHERE product_type = 'Internet');

--Which customers are paying more than the average Internet price?

SELECT email
FROM customer_subscriptions
WHERE price > (
    SELECT AVG(monthly_price)
    FROM products
    WHERE product_type = 'Internet');

--Which customers are paying less than the average Internet price?

SELECT email
FROM customer_subscriptions
WHERE price < (
    SELECT AVG(monthly_price)
    FROM products
    WHERE product_type = 'Internet');

--Which customers are subscribed to the most expensive product?

SELECT email
FROM customer_subscriptions
WHERE product_id IN (
    SELECT product_id
    FROM products
    WHERE monthly_price = (
        SELECT MAX(monthly_price)
        FROM products));

--Which customers are subscribed to the least expensive product?

SELECT email
FROM customer_subscriptions
WHERE product_id IN (
    SELECT product_id
    FROM products
    WHERE monthly_price = (
        SELECT MIN(monthly_price)
        FROM products));

--Which Internet products are priced above the average Internet product price?

SELECT product_name
FROM products
WHERE product_type = 'Internet'
AND monthly_price > (
    SELECT AVG(monthly_price)
    FROM products
    WHERE product_type = 'Internet');

