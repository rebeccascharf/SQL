## SQL Analysis

### 1. Suspects at the Crime Scene

```sql
SELECT suspect_first_name,
       suspect_last_name,
       cell_location,
       date_time
FROM suspect_info
JOIN location_info
  ON suspect_info.suspect_id = location_info.suspect_id
WHERE cell_location = 'Carnival City'
  AND date_time = '01/13/21 17:01';
2. Suspects with Specialist Associates
SELECT suspect_first_name,
       suspect_last_name,
       associate_alias,
       occupation,
       relationship_to_suspect
FROM suspect_info
JOIN associates_info
  ON suspect_info.suspect_id = associates_info.suspect_id
WHERE relationship_to_suspect = 'Friend'
  AND occupation LIKE '%Specialist%';
3. Suspects with Matching Vehicle Description
SELECT suspect_first_name,
       suspect_last_name,
       cell_location,
       car_model,
       license_plate
FROM suspect_info
JOIN vehicle_info
  ON suspect_info.suspect_id = vehicle_info.suspect_id
JOIN location_info
  ON suspect_info.suspect_id = location_info.suspect_id
WHERE car_type = 'Minivan'
  AND license_plate LIKE '%D0G';
4. Suspicious Alibi Statements
SELECT suspect_first_name,
       suspect_last_name,
       alibi_statement
FROM suspect_info
JOIN alibi_info
  ON suspect_info.suspect_id = alibi_info.suspect_id
WHERE alibi_statement LIKE '%dog%'
   OR alibi_statement LIKE '%cotton%'
   OR alibi_statement LIKE '%candy%';
5. Mismatched Location Data
SELECT suspect_info.suspect_id,
       suspect_first_name,
       suspect_last_name,
       cell_location,
       alibi_location
FROM suspect_info
JOIN alibi_info
  ON suspect_info.suspect_id = alibi_info.suspect_id
JOIN location_info
  ON suspect_info.suspect_id = location_info.suspect_id
WHERE cell_location <> alibi_location;
6. Final Suspect Identification
SELECT s.suspect_id,
       s.suspect_first_name,
       s.suspect_last_name
FROM suspect_info s
JOIN (
    SELECT suspect_id
    FROM (
        SELECT DISTINCT si.suspect_id
        FROM suspect_info si
        JOIN location_info li
          ON si.suspect_id = li.suspect_id
        WHERE li.cell_location = 'Carnival City'
          AND li.date_time = '01/13/21 17:01'

        UNION ALL

        SELECT DISTINCT si.suspect_id
        FROM suspect_info si
        JOIN associates_info ai
          ON si.suspect_id = ai.suspect_id
        WHERE ai.relationship_to_suspect = 'Friend'
          AND ai.occupation LIKE '%Specialist%'

        UNION ALL

        SELECT DISTINCT si.suspect_id
        FROM suspect_info si
        JOIN vehicle_info vi
          ON si.suspect_id = vi.suspect_id
        JOIN location_info li
          ON si.suspect_id = li.suspect_id
        WHERE vi.car_type = 'Minivan'
          AND vi.license_plate LIKE '%D0G'

        UNION ALL

        SELECT DISTINCT si.suspect_id
        FROM suspect_info si
        JOIN alibi_info ai
          ON si.suspect_id = ai.suspect_id
        WHERE ai.alibi_statement LIKE '%dog%'
           OR ai.alibi_statement LIKE '%cotton%'
           OR ai.alibi_statement LIKE '%candy%'

        UNION ALL

        SELECT DISTINCT si.suspect_id
        FROM suspect_info si
        JOIN alibi_info ai
          ON si.suspect_id = ai.suspect_id
        JOIN location_info li
          ON si.suspect_id = li.suspect_id
        WHERE li.cell_location <> ai.alibi_location
    ) all_clues
    GROUP BY suspect_id
    HAVING COUNT(*) = 5
) matches
  ON s.suspect_id = matches.suspect_id;
Key Insight

The suspect identified across all clue results was Pippa Puffloon.

